{
  "base": "vs-dark",
  "inherit": true,
  "rules": [
    { "token": "comment", "foreground": "#928374", "fontStyle": "italic" },
    { "token": "keyword", "foreground": "#fb4934", "fontStyle": "bold" },
    { "token": "operator", "foreground": "#fb4934" },
    { "token": "string", "foreground": "#b8bb26" },
    { "token": "number", "foreground": "#d3869b" },
    { "token": "constant", "foreground": "#d3869b" },
    { "token": "type", "foreground": "#fabd2f" },
    { "token": "class", "foreground": "#fabd2f" },
    { "token": "function", "foreground": "#b8bb26" },
    { "token": "method", "foreground": "#b8bb26" },
    { "token": "variable", "foreground": "#83a598" },
    { "token": "parameter", "foreground": "#83a598" },
    { "token": "property", "foreground": "#83a598" },
    { "token": "tag", "foreground": "#83a598" },
    { "token": "attribute", "foreground": "#8ec07c" },
    { "token": "regexp", "foreground": "#8ec07c" },
    { "token": "builtin", "foreground": "#fe8019" },
    { "token": "punctuation", "foreground": "#ebdbb2" },
    { "token": "delimiter", "foreground": "#ebdbb2" },
    { "token": "boolean", "foreground": "#d3869b" },
    { "token": "namespace", "foreground": "#fabd2f" }
  ],
  "colors": {
    "editor.background": "#1d2021",
    "editor.foreground": "#f9f5d7",
    "editorCursor.foreground": "#fe8019",
    "editorLineNumber.foreground": "#665c54",
    "editor.selectionBackground": "#32302f",
    "editor.inactiveSelectionBackground": "#32302f",
    "editorIndentGuide.background": "#3c3836",
    "editorIndentGuide.activeBackground": "#928374"
  }
}
